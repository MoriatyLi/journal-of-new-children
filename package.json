{
  "name": "openjournal-protocol",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run compile:contracts && vite build",
    "preview": "vite preview",
    "compile:contracts": "node scripts/compile-contracts.mjs",
    "deploy:contracts": "node scripts/deploy-contracts.mjs",
    "test": "npm run test:contracts && npm run test:web",
    "test:contracts": "node --test tests/contracts/*.test.mjs",
    "test:web": "vitest run",
    "test:web:watch": "vitest"
  },
  "dependencies": {
    "ethers": "^6.15.0",
    "ganache": "^7.9.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "solc": "^0.8.30",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "jsdom": "^27.0.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
